{
  "version": 2,
  "builds": [
    { "src": "api/run.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/run.js" },
    { "src": "/", "dest": "/index.html" }
  ],
  "functions": {
    "api/run.js": { "maxDuration": 30 }
  }
}
