{
  "version": 2,
  "builds": [
    { "src": "**/*.html", "use": "@vercel/static" },
    { "src": "css/**", "use": "@vercel/static" },
    { "src": "js/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/tiktok", "dest": "/tiktok.html" },
    { "src": "/instagram", "dest": "/instagram.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}